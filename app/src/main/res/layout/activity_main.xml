<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/tv_selected_app"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/no_app_selected"
        android:textSize="14sp"
        android:padding="8dp" />

    <Button
        android:id="@+id/btn_select_app"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/btn_select_app" />

    <Button
        android:id="@+id/btn_add_config"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/btn_add_config"
        android:layout_marginTop="8dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="已保存配置（点击选择）："
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="8dp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_configs"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <Button
        android:id="@+id/btn_start"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/btn_start"
        android:textSize="18sp"
        android:layout_marginTop="12dp"
        android:backgroundTint="@color/primary" />

</LinearLayout>
