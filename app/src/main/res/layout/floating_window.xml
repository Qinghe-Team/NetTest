<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/floating_root"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/floating_bg"
    android:minWidth="180dp">

    <!-- Collapsed drag handle / expand button -->
    <LinearLayout
        android:id="@+id/layout_collapsed"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <!-- Tap anywhere on this row to expand/collapse -->
        <ImageButton
            android:id="@+id/btn_floating_expand"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@mipmap/ic_launcher"
            android:background="@color/btn_normal"
            android:scaleType="centerCrop"
            android:contentDescription="expand" />
    </LinearLayout>

    <!-- Expanded panel -->
    <LinearLayout
        android:id="@+id/layout_expanded"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone">

        <!-- Row 1: 3 square icon buttons, no gaps, equal width -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/btn_floating_toggle"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:src="@drawable/ic_power"
                android:background="@color/btn_normal"
                android:scaleType="center"
                android:contentDescription="start/stop" />

            <ImageButton
                android:id="@+id/btn_floating_protocol"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:src="@drawable/ic_protocol"
                android:background="@color/btn_normal"
                android:scaleType="center"
                android:contentDescription="protocol" />

            <ImageButton
                android:id="@+id/btn_floating_close"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:src="@drawable/ic_close"
                android:background="@color/btn_normal"
                android:scaleType="center"
                android:contentDescription="close" />
        </LinearLayout>

        <!-- Protocol label (updates on tap of protocol button) -->
        <TextView
            android:id="@+id/tv_protocol_label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="协议: 全部"
            android:textColor="@color/white"
            android:textSize="11sp"
            android:gravity="center"
            android:paddingTop="4dp"
            android:paddingBottom="2dp"
            android:background="@color/floating_bg" />

        <!-- Config tiles – populated dynamically -->
        <LinearLayout
            android:id="@+id/layout_configs"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

    </LinearLayout>

</LinearLayout>
