<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="264dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/floating_panel_bg"
    android:padding="6dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <ImageButton
            android:id="@+id/btn_floating_toggle"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:background="@drawable/floating_tile_normal"
            android:contentDescription="@string/floating_toggle"
            android:padding="16dp"
            android:src="@drawable/ic_power"
            android:tint="@color/white" />

        <ImageButton
            android:id="@+id/btn_floating_refresh"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:background="@drawable/floating_tile_normal"
            android:contentDescription="@string/floating_refresh"
            android:padding="16dp"
            android:src="@drawable/ic_refresh"
            android:tint="@color/white" />

        <ImageButton
            android:id="@+id/btn_floating_expand"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:background="@drawable/floating_tile_normal"
            android:contentDescription="@string/floating_expand"
            android:padding="16dp"
            android:src="@drawable/ic_expand_less"
            android:tint="@color/white" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layout_expanded"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <GridLayout
            android:id="@+id/grid_configs"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="3"
            android:rowCount="1"
            android:useDefaultMargins="false" />
    </LinearLayout>

</LinearLayout>
