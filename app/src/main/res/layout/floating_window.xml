<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/fw_root"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/floating_bg_shape">

    <!-- Top bar: 3 square buttons in a row, no gaps -->
    <LinearLayout
        android:id="@+id/top_bar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/img_icon"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_gravity="center_vertical"
            android:padding="2dp"
            android:layout_marginStart="2dp"
            android:src="@drawable/ic_launcher_foreground"
            android:scaleType="fitCenter"
            android:background="@drawable/btn_square_grey" />

        <ImageView
            android:id="@+id/img_start"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_gravity="center_vertical"
            android:src="@drawable/ic_play_arrow"
            android:scaleType="fitCenter"
            android:background="@drawable/btn_square_grey" />

        <ImageView
            android:id="@+id/img_expand"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_gravity="center_vertical"
            android:src="@drawable/ic_expand_more"
            android:scaleType="fitCenter"
            android:background="@drawable/btn_square_grey" />
    </LinearLayout>

    <!-- Expanded config list - flat tiled, aligned with top bar -->
    <LinearLayout
        android:id="@+id/layout_expanded"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone">

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginStart="2dp"
            android:layout_marginEnd="2dp"
            android:background="#20000000" />

        <ListView
            android:id="@+id/lv_configs"
            android:layout_width="125dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="2dp"
            android:layout_marginEnd="2dp"
            android:layout_marginBottom="2dp"
            android:divider="#20000000"
            android:dividerHeight="1dp"
            android:choiceMode="singleChoice" />
    </LinearLayout>

</LinearLayout>
